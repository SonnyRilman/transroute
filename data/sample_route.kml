<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>TransJogja Sample Routes to Malioboro</name>
    <description>Simulasi data rute dan halte TransJogja di sekitar Malioboro untuk testing Algoritma Dijkstra.</description>

    <!-- Node/Halte -->
    <Placemark>
      <name>Halte Tugu Jogja</name>
      <description>Node: Tugu</description>
      <Point>
        <coordinates>110.367098,-7.782815,0</coordinates>
      </Point>
    </Placemark>
    <Placemark>
      <name>Halte Mangkubumi</name>
      <description>Node: Mangkubumi</description>
      <Point>
        <coordinates>110.366710,-7.787121,0</coordinates>
      </Point>
    </Placemark>
    <Placemark>
      <name>Halte Malioboro 1</name>
      <description>Node: Malioboro (Tujuan Utama)</description>
      <Point>
        <coordinates>110.366222,-7.792510,0</coordinates>
      </Point>
    </Placemark>
    <Placemark>
      <name>Halte Kleringan</name>
      <description>Node: Kleringan</description>
      <Point>
        <coordinates>110.369796,-7.789230,0</coordinates>
      </Point>
    </Placemark>
    <Placemark>
      <name>Halte Kotabaru</name>
      <description>Node: Kotabaru</description>
      <Point>
        <coordinates>110.373264,-7.784910,0</coordinates>
      </Point>
    </Placemark>
    <Placemark>
      <name>Halte RS Bethesda</name>
      <description>Node: Bethesda</description>
      <Point>
        <coordinates>110.377312,-7.783451,0</coordinates>
      </Point>
    </Placemark>
    
    <!-- Edges/Jalur Bus -->
    <Placemark>
      <name>Jalur Tugu - Mangkubumi</name>
      <LineString>
        <coordinates>
          110.367098,-7.782815,0
          110.366710,-7.787121,0
        </coordinates>
      </LineString>
    </Placemark>
    <Placemark>
      <name>Jalur Mangkubumi - Malioboro 1</name>
      <LineString>
        <coordinates>
          110.366710,-7.787121,0
          110.366222,-7.792510,0
        </coordinates>
      </LineString>
    </Placemark>
    <Placemark>
      <name>Jalur Tugu - Kotabaru</name>
      <LineString>
        <coordinates>
          110.367098,-7.782815,0
          110.373264,-7.784910,0
        </coordinates>
      </LineString>
    </Placemark>
    <Placemark>
      <name>Jalur Kotabaru - Kleringan</name>
      <LineString>
        <coordinates>
          110.373264,-7.784910,0
          110.369796,-7.789230,0
        </coordinates>
      </LineString>
    </Placemark>
    <Placemark>
      <name>Jalur Kleringan - Malioboro 1</name>
      <LineString>
        <coordinates>
          110.369796,-7.789230,0
          110.366222,-7.792510,0
        </coordinates>
      </LineString>
    </Placemark>
    <Placemark>
      <name>Jalur Bethesda - Kotabaru</name>
      <LineString>
        <coordinates>
          110.377312,-7.783451,0
